generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Um conteúdo SDUI. O `spec` é JSONB opaco: o backend NÃO interpreta o
/// conteúdo — o kernel de validação é Dart (`sdui_core`). Multi-tenant
/// preparado por `projectId`; `slug` é a referência técnica única por projeto
/// (papéis/workflow chegam no I4). Novos registros nascem com id CUID2;
/// UUIDs legados permanecem válidos.
model Content {
  id          String   @id @default(cuid(2))
  projectId   String   @default("default") @map("project_id")
  name        String
  slug        String
  description String?
  spec        Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("contents")
}
