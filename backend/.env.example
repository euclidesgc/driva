# Copie para .env (o .env não é versionado). Em hml/prod estes valores são
# definidos no Coolify, nunca no repositório.

# Conexão do Postgres. Em dev, casa com backend/docker-compose.yml (porta 5433).
DATABASE_URL="postgresql://driva:driva@localhost:5433/driva?schema=public"

# Porta HTTP do Nest.
PORT=3000

# Origens permitidas no CORS, separadas por vírgula (ex.:
# https://hml.driva.duckdns.org). Se vazio, libera qualquer localhost.
CORS_ORIGINS=

# StorageService (port em src/storage/): driver do adapter concreto.
# "local" (default, dev) grava em STORAGE_LOCAL_DIR, fora de webroot.
# "s3" (adapter pronto em s3-storage.service.ts) — NÃO ligar em hml/prod sem
# credenciais S3-compatíveis definidas por env no Coolify (Decisão 4 do
# prd.md: Garage vs R2, ainda parada). Requer as envs S3_* abaixo.
#
# Em ambos os drivers a key é organizada em pasta por projeto:
# `<projectId>/midias/<uuid>.<ext>` — <projectId> é o id do Project (estável),
# não o título; o nome do arquivo continua um UUID gerado pelo servidor
# (key não-enumerável).
STORAGE_DRIVER=local

# Pasta do adapter local, relativa ao cwd do processo Nest. Default ".storage".
STORAGE_LOCAL_DIR=.storage

# --- Só usadas quando STORAGE_DRIVER=s3 (segredo real nunca no repo/aqui) ---
# Endpoint S3-compatível: em hml/prod, Garage em `https://s3.bmjtech.duckdns.org`.
# Vazio = AWS S3 real.
S3_ENDPOINT=
# Bucket de destino das imagens de Project (pastas por projeto dentro dele).
S3_BUCKET=
# Credenciais da chave de acesso — só como env/Build Variable no Coolify,
# nunca comitar valores reais.
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Região (default "auto", aceito por Garage/R2). No Garage do projeto: "garage".
S3_REGION=auto
# Prefixo raiz opcional para namespacear a app dentro de um bucket compartilhado
# por vários serviços/ambientes (ex.: "driva-hml" / "driva-prod"). A key final
# fica `<S3_KEY_PREFIX>/<projectId>/midias/<uuid>.<ext>`. Vazio = raiz do bucket.
S3_KEY_PREFIX=
