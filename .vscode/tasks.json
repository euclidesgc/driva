{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "db up (postgres local)",
      "type": "shell",
      "command": "docker compose up -d",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "db down (postgres local)",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "// backend up (bg)": "Sobe Postgres + schema + Nest em watch, numa task de shell (PATH completo, acha o pnpm do nvm). \u00c9 o preLaunchTask do 'editor \u25b6 local (dev)': roda em background e o editor s\u00f3 lan\u00e7a quando o Nest sobe (endsPattern). Um F5 levanta tudo.",
      "label": "backend up (bg)",
      "type": "shell",
      "isBackground": true,
      "command": "bash \"${workspaceFolder}/.vscode/scripts/backend-up.sh\" \"${workspaceFolder}/.vscode/backend.pid\"",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Nest application successfully started"
        }
      }
    },
    {
      "label": "backend down (bg)",
      "type": "shell",
      "command": "bash \"${workspaceFolder}/.vscode/scripts/backend-down.sh\" \"${workspaceFolder}/.vscode/backend.pid\"",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "prepara backend (db + schema)",
      "type": "shell",
      "command": "bash \"${workspaceFolder}/.vscode/scripts/prepara-backend.sh\"",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "e2e (conte\u00fados)",
      "type": "shell",
      "command": "./docs/02-conteudos/e2e.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
