# Dart / Flutter
.dart_tool/
build/
*.iml
.idea/
# .metadata do Flutter DEVE ser versionado (marca o projeto como app Flutter + plataformas;
# sem ele o VSCode dá "Unable to launch Flutter project in a Dart-only workspace").

# Segredos — nunca versionar (ex.: COOLIFY_TOKEN)
.env
!.env.example

# Backend (Node)
node_modules/
backend/dist/
backend/*.tsbuildinfo
backend/.env
# Adapter local do StorageService (dev) — binários de objetos armazenados,
# nunca versionados; fora de qualquer webroot servido estaticamente.
backend/.storage/

# Artefatos transitórios do E2E (o e2e.sh cria; `down` remove). São sobrescritos a
# cada run — não são evidência (as evidências são os PNGs + o snapshot do e2e.sh).
# double-star cobre a raiz da feature E as subpastas evidencias/rodada_MM/.
docs/**/.e2e-backend.*

# Artefatos de diff de golden test (o Flutter gera em falha)
**/test/**/failures/

# Sistema
.DS_Store
.claude/settings.local.json
.vscode/backend.pid
